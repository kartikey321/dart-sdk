FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/dart-zig
COPY dart-zig-linux-x64.tar.gz /tmp/dart-zig-linux-x64.tar.gz
RUN tar -C /opt/dart-zig --strip-components=1 -xzf /tmp/dart-zig-linux-x64.tar.gz \
    && rm /tmp/dart-zig-linux-x64.tar.gz

ENV LD_LIBRARY_PATH=/opt/dart-zig/lib
